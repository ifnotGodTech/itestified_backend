DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
POSTGRES_DB=itestified
POSTGRES_USER=itestified
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
OTP_HINT_IN_RESPONSE=false

# Super admin bootstrap testing
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_FULL_NAME=Super Admin

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-google-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=iTestified <your-gmail-address@gmail.com>
SUPPORT_EMAIL=support@itestified.app

# Mobile Google Sign-In (Phase 2)
# Comma-separated list of accepted OAuth client IDs (Android/iOS/Web as needed)
GOOGLE_OAUTH_CLIENT_IDS=your-android-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com
# Optional: enforce issuer checks for Google identity tokens
GOOGLE_OAUTH_ALLOWED_ISSUERS=https://accounts.google.com,accounts.google.com

# to bootstrap the super admin, run the following command after setting the environment variables:

./.venv/bin/python backend/manage.py bootstrap_super_admin \
  --email "your-email@example.com" \
  --full-name "Your Name"

#   Super admin bootstrap completed.
